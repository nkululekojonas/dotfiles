[core]
    excludesfile = ~/.config/git/gitignore_global
	editor = vim
	eol = lf
	autocrlf = false
[init]
	defaultBranch = main
[user]
	name = Nkululeko Jonas 
	email = nkululekojonas@gmail.com
[fsck]
	zeroPaddedFilemode = ignore
[fetch "fsck"]
	zeroPaddedFilemode = ignore
[receive "fsck"]
	zeroPaddedFilemode = ignore
[oh-my-zsh]
	lastVersion = fd8f72b27614d48ec06421fb80aff2eb10674a69
