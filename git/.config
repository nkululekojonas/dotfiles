[core]
    excludesfile = ~/.config/git/gitignore_global
	editor = vim
	eol = lf
	autocrlf = false
[init]
	defaultBranch = main
[user]
	name = Nkululeko Jonas 
	email = nkululekojonas@gmail.com
[fsck]
	zeroPaddedFilemode = ignore
[fetch "fsck"]
	zeroPaddedFilemode = ignore
[receive "fsck"]
	zeroPaddedFilemode = ignore
[oh-my-zsh]
	lastVersion = 01a955657408c8396fc947075a912ee868d5e2a7
