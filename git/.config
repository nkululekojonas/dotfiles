[core]
    excludesfile = ~/.config/git/ignore
	editor = vim
	eol = lf
	autocrlf = false
[init]
	defaultBranch = main
[user]
	name = Nkululeko Jonas 
	email = nkululekojonas@gmail.com
[fsck]
	zeroPaddedFilemode = ignore
[fetch "fsck"]
	zeroPaddedFilemode = ignore
[receive "fsck"]
	zeroPaddedFilemode = ignore
[oh-my-zsh]
	lastVersion = dd4be1b6fb9973d63eba334d8bd92b3da30b3e72
